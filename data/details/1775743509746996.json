                "__isComposedBlockWithEntities": "ComposedHeaderTwoBlockWithEntities",
                "block_type": "HEADER_TWO",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [],
                "text": "TÂM SỰ:"
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [],
                "text": "- Nếu bạn muốn bảo mật, hỗ trợ lâu dài, chức năng mới liên tục, thì nên tránh mấy bản cờ rắc"
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [],
                "text": "- Giá của FB AIO cũng quá bèo, không đáng đánh đổi để phải dùng cờ rắc như trên"
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
                "data": "{}",
