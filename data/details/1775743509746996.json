                ],
                "text": "- Nên anh ta cay, anh ta tìm cách cờ rắc luôn FB AIO"
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [],
                "text": "- Nay mình đã thấy repo ở trên"
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [],
                "text": ""
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [],
                "text": "---------------"
            },
            {
                "__typename": "ComposedHeaderTwoBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedHeaderTwoBlockWithEntities",
                "block_type": "HEADER_TWO",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [],
                "text": "Phương pháp:"
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [],
                "text": "- Mình nói thẳng luôn phương pháp cho các cờ rắc cơ sau đỡ phải mất thời gian"
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [
                    {
                        "inline_style": "UNDERLINE",
                        "length": 19,
                        "offset": 33
                    },
                    {
                        "inline_style": "UNDERLINE",
                        "length": 15,
                        "offset": 87
                    }
                ],
                "text": "- Mọi chức năng FB AIO đều gọi ở phía máy người dùng, không có server chung gian (giúp bảo mật dữ liệu khách hàng)"
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [
                    {
                        "inline_style": "UNDERLINE",
                        "length": 12,
                        "offset": 21
                    }
                ],
                "text": "- Chỉ có khi nào cần kiểm tra VIP, thì mới gọi API tới server để kiểm tra thôi"
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [],
                "text": "- Mấy anh bạn cờ rắc nhắm vào chỗ đó để phake dữ liệu trả về, hoặc sửa code để ko kiểm tra VIP nữa"
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
                "data": "{}",
                "depth": 0,
                "media_alignment": null,
                "media_caption": null,
                "entity_ranges": [],
                "inline_style_ranges": [
                    {
                        "inline_style": "UNDERLINE",
                        "length": 22,
                        "offset": 23
                    }
                ],
                "text": "- Nhưng họ thường phải sửa lại code trang web, hoặc code extension"
            },
            {
                "__typename": "ComposedUnstyledBlockWithEntities",
                "__isComposedBlockWithEntities": "ComposedUnstyledBlockWithEntities",
                "block_type": "UNSTYLED",
